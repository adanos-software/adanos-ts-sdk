{
  "name": "finance-sentiment",
  "version": "1.3.0",
  "description": "TypeScript SDK for the Adanos Market Sentiment API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "adanos",
    "finance",
    "sentiment",
    "stocks",
    "trading",
    "reddit",
    "x",
    "twitter",
    "polymarket",
    "typescript",
    "sdk",
    "api"
  ],
  "author": "Alexander Schneider",
  "license": "MIT",
  "homepage": "https://adanos.org",
  "bugs": {
    "url": "https://github.com/adanos-software/adanos-ts-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adanos-software/adanos-ts-sdk"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
